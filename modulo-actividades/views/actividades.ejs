<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Actividades — Club Médanos Verdes</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
    <style>
        .card-desc { font-size: var(--text-sm); color: var(--neutral-500); }
        .card-detail { font-size: var(--text-sm); margin-bottom: var(--space-sm); }
        .card-detail-label { color: var(--neutral-400); }
        .card-detail-value { color: var(--neutral-900); font-weight: var(--weight-semibold); }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🏊 Actividades</h1>
            <p>Natación, tenis, gimnasia y más disciplinas deportivas</p>
        </div>

        <div class="top-bar">
            <button class="btn btn-primary" onclick="abrirModalCrear()">+ Nueva actividad</button>
            <a href="/dashboard" class="btn btn-secondary">← Volver al dashboard</a>
        </div>

        <div class="search-bar">
            <input type="text" id="searchInput" placeholder="Buscar actividad..." onkeyup="filtrarActividades()">
        </div>

        <div class="activities-grid" id="activitiesGrid">
            <div style="grid-column: 1/-1; text-align: center; padding: 40px; color: #94a3b8;">Cargando actividades...</div>
        </div>
    </div>

    <!-- Modal Crear/Editar -->
    <div class="modal" id="modalActividad">
        <div style="position: relative;">
            <button class="modal-close" onclick="cerrarModal('modalActividad')">✕</button>
            <div class="modal-content">
                <div class="modal-header" id="modalTitle">Nueva actividad</div>
                <form id="actividadForm" onsubmit="guardarActividad(event)">
                    <div class="form-group">
                        <label>Nombre *</label>
                        <input type="text" id="nombre" required>
                    </div>
                    <div class="form-group">
                        <label>Descripción</label>
                        <textarea id="descripcion" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Días y horarios</label>
                        <input type="text" id="dias_horario" placeholder="ej: Lu-Mi-Vi 18:00">
                    </div>
                    <div class="form-group">
                        <label>Precio base</label>
                        <input type="number" id="precio_base" step="0.01" value="0">
                    </div>
                    <div class="form-group" id="activoGroup" style="display: none;">
                        <label>
                            <input type="checkbox" id="activo" checked> Activo
                        </label>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn-submit">Guardar</button>
                        <button type="button" class="btn-cancel" onclick="cerrarModal('modalActividad')">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Instructores -->
    <div class="modal" id="modalInstructores">
        <div style="position: relative;">
            <button class="modal-close" onclick="cerrarModal('modalInstructores')">✕</button>
            <div class="modal-content">
                <div class="modal-header" id="instructoresTitle">Instructores</div>

                <div style="margin-bottom: 24px;">
                    <h4 style="font-size: var(--text-lg); font-weight: var(--weight-semibold); margin-bottom: 12px; color: var(--neutral-900);">Instructores asignados</h4>
                    <div id="instructoresAsignados" style="display: flex; flex-direction: column; gap: 8px;">
                        <div style="color: var(--neutral-400); font-size: var(--text-sm);">Cargando...</div>
                    </div>
                </div>

                <div style="border-top: 1px solid var(--neutral-200); padding-top: 24px;">
                    <h4 style="font-size: var(--text-lg); font-weight: var(--weight-semibold); margin-bottom: 12px; color: var(--neutral-900);">Asignar nuevo</h4>
                    <div style="display: flex; gap: 12px; align-items: flex-end;">
                        <div style="flex: 1;">
                            <label style="display: block; font-size: var(--text-sm); font-weight: var(--weight-semibold); margin-bottom: 8px; color: var(--neutral-700);">Instructor</label>
                            <select id="selectInstructor" style="width: 100%; padding: 10px; border: 1px solid var(--neutral-200); border-radius: var(--radius-md); font-family: var(--font-sans);">
                                <option value="">Seleccionar instructor...</option>
                            </select>
                        </div>
                        <button type="button" class="btn btn-primary" style="white-space: nowrap;" onclick="asignarInstructorActividad()">Asignar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        let allActividades = [];
        let editandoId = null;

        async function cargarActividades() {
            try {
                const r = await fetch('/api/actividades', { credentials: 'include' });
                const d = await r.json();
                if (d.success) {
                    allActividades = d.actividades || [];
                    renderActividades();
                }
            } catch (err) {
                console.error(err);
            }
        }

        function renderActividades() {
            const grid = document.getElementById('activitiesGrid');
            if (allActividades.length === 0) {
                grid.innerHTML = '<div style="grid-column: 1/-1; text-align: center; padding: 40px; color: #94a3b8;">No hay actividades</div>';
                return;
            }
            grid.innerHTML = allActividades.map(a => `
                <div class="activity-card">
                    <div class="card-header">
                        <div class="card-title">${a.nombre}</div>
                        <div class="card-desc">${a.descripcion || 'Sin descripción'}</div>
                    </div>
                    <div class="card-body">
                        <div class="card-detail">
                            <span class="card-detail-label">Horario:</span>
                            <span class="card-detail-value">${a.dias_horario || 'Sin definir'}</span>
                        </div>
                        <div class="card-detail">
                            <span class="card-detail-label">Precio base:</span>
                            <span class="card-detail-value">$${a.precio_base.toFixed(2)}</span>
                        </div>
                    </div>
                    <div class="card-actions">
                        <button class="btn-action btn-edit" onclick="abrirModalEditar(${a.id})">Editar</button>
                        <button class="btn-action btn-config" onclick="abrirModalInstructores(${a.id})">Instructores</button>
                    </div>
                </div>
            `).join('');
        }

        function filtrarActividades() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const filtered = allActividades.filter(a =>
                a.nombre.toLowerCase().includes(search) ||
                (a.descripcion && a.descripcion.toLowerCase().includes(search))
            );
            const grid = document.getElementById('activitiesGrid');
            if (filtered.length === 0) {
                grid.innerHTML = '<div style="grid-column: 1/-1; text-align: center; padding: 40px; color: #94a3b8;">No hay actividades que coincidan</div>';
                return;
            }
            grid.innerHTML = filtered.map(a => `
                <div class="activity-card">
                    <div class="card-header">
                        <div class="card-title">${a.nombre}</div>
                        <div class="card-desc">${a.descripcion || 'Sin descripción'}</div>
                    </div>
                    <div class="card-body">
                        <div class="card-detail">
                            <span class="card-detail-label">Horario:</span>
                            <span class="card-detail-value">${a.dias_horario || 'Sin definir'}</span>
                        </div>
                        <div class="card-detail">
                            <span class="card-detail-label">Precio base:</span>
                            <span class="card-detail-value">$${a.precio_base.toFixed(2)}</span>
                        </div>
                    </div>
                    <div class="card-actions">
                        <button class="btn-action btn-edit" onclick="abrirModalEditar(${a.id})">Editar</button>
                        <button class="btn-action btn-config" onclick="abrirModalInstructores(${a.id})">Instructores</button>
                    </div>
                </div>
            `).join('');
        }

        function abrirModalCrear() {
            editandoId = null;
            document.getElementById('modalTitle').textContent = 'Nueva actividad';
            document.getElementById('actividadForm').reset();
            document.getElementById('activoGroup').style.display = 'none';
            document.getElementById('modalActividad').classList.add('active');
        }

        async function abrirModalEditar(id) {
            try {
                const r = await fetch(`/api/actividades/${id}`, { credentials: 'include' });
                const d = await r.json();
                if (d.success) {
                    const a = d.actividad;
                    editandoId = id;
                    document.getElementById('modalTitle').textContent = 'Editar actividad';
                    document.getElementById('nombre').value = a.nombre;
                    document.getElementById('descripcion').value = a.descripcion || '';
                    document.getElementById('dias_horario').value = a.dias_horario || '';
                    document.getElementById('precio_base').value = a.precio_base || 0;
                    document.getElementById('activo').checked = a.activo;
                    document.getElementById('activoGroup').style.display = 'block';
                    document.getElementById('modalActividad').classList.add('active');
                }
            } catch (err) {
                alert('Error al cargar actividad');
            }
        }

        async function guardarActividad(e) {
            e.preventDefault();
            const nombre = document.getElementById('nombre').value;
            const descripcion = document.getElementById('descripcion').value;
            const dias_horario = document.getElementById('dias_horario').value;
            const precio_base = parseFloat(document.getElementById('precio_base').value);

            try {
                if (editandoId) {
                    const activo = document.getElementById('activo').checked;
                    const r = await fetch(`/api/actividades/${editandoId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ nombre, descripcion, dias_horario, precio_base, activo })
                    });
                    const d = await r.json();
                    if (!d.success) {
                        alert('Error: ' + d.error);
                        return;
                    }
                } else {
                    const r = await fetch('/api/actividades', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ nombre, descripcion, dias_horario, precio_base })
                    });
                    const d = await r.json();
                    if (!d.success) {
                        alert('Error: ' + d.error);
                        return;
                    }
                }
                cerrarModal('modalActividad');
                cargarActividades();
            } catch (err) {
                alert('Error: ' + err.message);
            }
        }

        function cerrarModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        let actividadModalId = null;

        async function abrirModalInstructores(id) {
            actividadModalId = id;
            const actividad = allActividades.find(a => a.id === id);
            document.getElementById('instructoresTitle').textContent = `Instructores de ${actividad.nombre}`;

            try {
                // Cargar instructores asignados a esta actividad
                const r1 = await fetch(`/api/actividades/${id}`, { credentials: 'include' });
                const d1 = await r1.json();
                const asignados = d1.instructores || [];

                // Cargar todos los instructores activos
                const r2 = await fetch('/api/instructores', { credentials: 'include' });
                const d2 = await r2.json();
                const todos = d2.instructores || [];

                // Renderizar asignados
                const asignadosHtml = asignados.length === 0
                    ? '<div style="color: var(--neutral-400); font-size: var(--text-sm);">Sin instructores asignados</div>'
                    : asignados.map(i => `
                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 8px; background: var(--neutral-50); border-radius: var(--radius-md); border-left: 3px solid var(--primary);">
                            <span style="font-size: var(--text-sm);">${i.apellido}, ${i.nombre}</span>
                            <button type="button" class="btn btn-danger btn-sm" style="padding: 6px 12px; font-size: 12px;" onclick="desasignarInstructor(${i.id})">Quitar</button>
                        </div>
                    `).join('');

                document.getElementById('instructoresAsignados').innerHTML = asignadosHtml;

                // Renderizar dropdown de disponibles
                const disponibles = todos.filter(t => !asignados.some(a => a.id === t.id));
                const selectHtml = '<option value="">Seleccionar instructor...</option>' +
                    disponibles.map(i => `<option value="${i.id}">${i.apellido}, ${i.nombre}</option>`).join('');

                document.getElementById('selectInstructor').innerHTML = selectHtml;

                // Abrir modal
                document.getElementById('modalInstructores').classList.add('active');
            } catch (err) {
                alert('Error al cargar instructores: ' + err.message);
                console.error(err);
            }
        }

        async function asignarInstructorActividad() {
            const instructorId = document.getElementById('selectInstructor').value;
            if (!instructorId) {
                alert('Por favor selecciona un instructor');
                return;
            }

            try {
                const r = await fetch(`/api/actividades/${actividadModalId}/instructores`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ instructor_id: parseInt(instructorId) })
                });
                const d = await r.json();
                if (!d.success) {
                    alert('Error: ' + d.error);
                    return;
                }
                abrirModalInstructores(actividadModalId);
            } catch (err) {
                alert('Error: ' + err.message);
            }
        }

        async function desasignarInstructor(instructorId) {
            try {
                const r = await fetch(`/api/actividades/${actividadModalId}/instructores/${instructorId}`, {
                    method: 'DELETE',
                    credentials: 'include'
                });
                const d = await r.json();
                if (!d.success) {
                    alert('Error: ' + d.error);
                    return;
                }
                abrirModalInstructores(actividadModalId);
            } catch (err) {
                alert('Error: ' + err.message);
            }
        }

        cargarActividades();
    </script>
</body>
</html>
