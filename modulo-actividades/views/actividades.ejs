<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Actividades — Club Médanos Verdes</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
    <style>
        /* ── BÚSQUEDA Y FILTROS ── */
        .busqueda-wrap { position: relative; margin-bottom: 14px; }
        .busqueda-wrap::before { content: '🔍'; position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 14px; pointer-events: none; }
        .busqueda-act {
            width: 100%; padding: 10px 16px 10px 42px; border: 1.5px solid var(--neutral-200);
            border-radius: 24px; font-size: var(--text-sm); box-sizing: border-box; background: white;
            transition: border-color 0.2s;
        }
        .busqueda-act:focus { outline: none; border-color: var(--primary); }
        .filtros-bar { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px; }
        .filtro-pill {
            padding: 6px 18px; border-radius: 24px; border: 1.5px solid var(--neutral-200);
            background: white; font-size: 13px; cursor: pointer; font-weight: 600;
            color: var(--neutral-600); transition: all 0.15s;
        }
        .filtro-pill.activo { background: var(--primary); color: white; border-color: var(--primary); }
        .filtro-pill:hover:not(.activo) { border-color: var(--primary); color: var(--primary); }

        /* ── GRID DE TARJETAS ── */
        .act-cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
            gap: 16px;
        }
        .act-card-v2 {
            background: white; border: 1.5px solid var(--neutral-200); border-radius: var(--radius-lg);
            padding: 20px; cursor: pointer; display: flex; flex-direction: column;
            transition: box-shadow 0.2s, border-color 0.2s, transform 0.1s;
        }
        .act-card-v2:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.1); border-color: var(--primary); transform: translateY(-2px); }
        .act-icon-wrap { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 26px; margin-bottom: 14px; }
        .act-card-v2-nombre { font-size: var(--text-lg); font-weight: var(--weight-bold); color: var(--neutral-900); margin-bottom: 4px; }
        .act-card-v2-desc { font-size: 13px; color: var(--neutral-500); margin-bottom: 10px; flex: 1; min-height: 18px; }
        .act-card-v2-instructores { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 12px; min-height: 22px; }
        .act-card-v2-footer {
            display: flex; justify-content: space-between; align-items: center;
            padding-top: 12px; border-top: 1px solid var(--neutral-100);
            font-size: 12px; color: var(--neutral-500);
        }
        .act-gestionar { color: var(--primary); font-weight: 700; font-size: 13px; }

        /* ── DRAG SELECTION ── */
        .grilla-slot.seleccionado {
            background: rgba(76,175,80,0.25) !important;
            border: 2px solid var(--primary) !important;
            color: var(--primary) !important;
        }
        /* ── CELDA SUBDIVIDIDA (cuartos de hora) ── */
        .grilla-slot.subdividida {
            padding: 2px; display: grid;
            grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr;
            gap: 2px; min-height: 48px;
        }
        .quarter-slot {
            border-radius: 3px; font-size: 9px; font-weight: 700;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            cursor: pointer; transition: all 0.1s; line-height: 1.2;
        }
        .quarter-slot.ocupado { background: var(--primary); color: white; }
        .quarter-slot.vacio { background: var(--neutral-100); border: 1px dashed var(--neutral-300); color: var(--neutral-400); }
        .quarter-slot.vacio:hover { background: #e8f5e9; border-color: var(--primary); color: var(--primary); }
        /* ── PLANTILLAS RÁPIDAS ── */
        .template-bar {
            display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
            margin-bottom: 16px; padding: 10px 14px;
            background: var(--neutral-50); border-radius: var(--radius-md); border: 1px solid var(--neutral-200);
        }
        .template-bar-label { font-size: 11px; font-weight: 700; color: var(--neutral-500); letter-spacing: 0.6px; white-space: nowrap; text-transform: uppercase; }
        .template-btn {
            padding: 5px 14px; border: 1.5px solid var(--neutral-300); border-radius: 20px;
            background: white; font-size: 12px; font-weight: 600; cursor: pointer;
            color: var(--neutral-700); transition: all 0.15s;
        }
        .template-btn:hover { border-color: var(--primary); color: var(--primary); background: #e8f5e9; }

        /* ── VISTA DE DETALLE ── */
        .detalle-header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 24px;
        }
        .btn-volver {
            background: var(--neutral-100);
            border: none;
            border-radius: var(--radius-md);
            padding: 8px 14px;
            cursor: pointer;
            font-size: var(--text-sm);
            font-weight: var(--weight-semibold);
            color: var(--neutral-700);
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .btn-volver:hover { background: var(--neutral-200); }

        /* ── GRILLA SEMANAL ── */
        .grilla-wrapper { overflow-x: auto; }
        .grilla {
            display: grid;
            grid-template-columns: 70px repeat(7, 1fr);
            gap: 3px;
            min-width: 700px;
        }
        .grilla-header {
            text-align: center;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.8px;
            color: var(--neutral-500);
            padding: 8px 4px;
            text-transform: uppercase;
        }
        .grilla-hora {
            font-size: 12px;
            color: var(--neutral-400);
            text-align: right;
            padding: 0 8px;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            font-weight: 600;
        }
        .grilla-slot {
            border-radius: 6px;
            padding: 6px 4px;
            text-align: center;
            font-size: 11px;
            min-height: 48px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: all 0.15s;
        }
        .grilla-slot.vacio {
            background: var(--neutral-50);
            border: 1px dashed var(--neutral-200);
            color: var(--neutral-300);
            cursor: pointer;
        }
        .grilla-slot.vacio:hover {
            background: #e8f5e9;
            border-color: var(--primary);
            color: var(--primary);
        }
        .grilla-slot.ocupado {
            background: var(--primary);
            color: white;
            cursor: pointer;
            border: 1px solid var(--primary);
        }
        .grilla-slot.ocupado:hover { opacity: 0.85; }
        .slot-count { font-size: 11px; font-weight: 700; }
        .slot-sub { font-size: 10px; opacity: 0.85; margin-top: 2px; }

        /* ── MODALES ── */
        .form-group { margin-bottom: 16px; }
        .form-group label { display: block; font-weight: var(--weight-semibold); margin-bottom: 6px; font-size: var(--text-sm); }
        .form-group input, .form-group select {
            width: 100%; padding: 10px 12px; border: 1px solid var(--neutral-200);
            border-radius: var(--radius-md); font-size: var(--text-sm); box-sizing: border-box;
        }
        .search-input { width: 100%; padding: 10px 12px; border: 1px solid var(--neutral-200); border-radius: var(--radius-md); font-size: var(--text-sm); box-sizing: border-box; margin-bottom: 8px; }
        .search-hint { font-size: 12px; color: var(--neutral-400); margin-bottom: 8px; }
        .search-results { max-height: 280px; overflow-y: auto; border: 1px solid var(--neutral-200); border-radius: var(--radius-md); background: white; }
        .search-result-item { padding: 10px 12px; cursor: pointer; border-bottom: 1px solid var(--neutral-100); font-size: var(--text-sm); }
        .search-result-item:last-child { border-bottom: none; }
        .search-result-item:hover { background: var(--primary); color: white; }
        .persona-item { display: flex; justify-content: space-between; align-items: center; padding: 6px 8px; background: var(--neutral-50); border-radius: var(--radius-sm); font-size: var(--text-sm); margin-bottom: 4px; }
        .remove-btn { background: none; border: none; color: #ef4444; cursor: pointer; font-weight: bold; padding: 0 4px; font-size: 16px; }
        .empty-message { color: var(--neutral-400); font-size: var(--text-sm); padding: 8px 0; }
        .section-subtitle { font-size: 11px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; color: var(--neutral-500); margin-bottom: 10px; }
    </style>
</head>
<body>
    <div class="container">

        <!-- ── VISTA LISTA ── -->
        <div id="vistaLista">
            <div class="header" style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;">
                <div>
                    <h1>Actividades</h1>
                    <p>Seleccioná una actividad para gestionar sus horarios</p>
                </div>
                <button class="btn btn-primary" onclick="abrirModalNuevaActividad()" style="margin-top:8px;">+ Nueva Actividad</button>
            </div>
            <div class="busqueda-wrap">
                <input type="text" id="busquedaActividades" class="busqueda-act" placeholder="Buscar por nombre o descripción..." oninput="filtrarActividades()">
            </div>
            <div class="filtros-bar">
                <button class="filtro-pill activo" onclick="setFiltro('todos', this)">Todas</button>
                <button class="filtro-pill" onclick="setFiltro('franjas', this)">Con horarios</button>
                <button class="filtro-pill" onclick="setFiltro('flexibles', this)">Flexibles</button>
            </div>
            <div id="listaActividades" class="act-cards-grid"></div>
        </div>

        <!-- ── VISTA DETALLE ── -->
        <div id="vistaDetalle" style="display:none;">
            <div class="detalle-header">
                <button onclick="volverALista()" style="background:var(--primary);color:white;border:none;border-radius:8px;padding:8px 16px;cursor:pointer;font-size:14px;font-weight:700;display:flex;align-items:center;gap:6px;white-space:nowrap;">&#8592; Volver</button>
                <h2 id="detalleNombre" style="margin:0;font-size:var(--text-2xl);flex:1;"></h2>
                <span id="detalleDesc" style="color:var(--neutral-500);font-size:var(--text-sm);margin-right:12px;"></span>
                <button style="color:#ef4444;border:1px solid #fca5a5;background:white;font-size:12px;padding:6px 12px;border-radius:6px;cursor:pointer;" onclick="eliminarActividadActual()">Eliminar actividad</button>
            </div>
            <div style="background:white;border:1px solid var(--neutral-200);border-radius:var(--radius-lg);padding:20px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
                    <p style="margin:0;font-size:var(--text-sm);color:var(--neutral-500);">
                        Haz click en un horario para activarlo. Haz click en uno verde para gestionar socios e instructores.
                    </p>
                    <div style="display:flex;gap:16px;font-size:12px;">
                        <span><span style="display:inline-block;width:12px;height:12px;background:var(--primary);border-radius:3px;margin-right:4px;"></span>Con socios</span>
                        <span><span style="display:inline-block;width:12px;height:12px;background:var(--neutral-100);border:1px dashed #ccc;border-radius:3px;margin-right:4px;"></span>Disponible</span>
                    </div>
                </div>
                <div class="template-bar">
                    <span class="template-bar-label">Plantillas:</span>
                    <button class="template-btn" onclick="aplicarPlantilla(0)">Lun-Mie-Vie</button>
                    <button class="template-btn" onclick="aplicarPlantilla(1)">Mar-Jue</button>
                    <button class="template-btn" onclick="aplicarPlantilla(2)">Lun a Vie</button>
                    <button class="template-btn" onclick="aplicarPlantilla(3)">Fin de semana</button>
                    <button class="template-btn" onclick="aplicarPlantilla(4)">Todos los dias</button>
                </div>
                <div class="grilla-wrapper" onmousemove="onGridMouseMove(event)" onmouseleave="cancelDragVisual()">
                    <div class="grilla" id="grillaHoraria"></div>
                </div>
            </div>
        </div>

    </div>

    <!-- Modal: Gestionar franja (socios + instructores) -->
    <div class="modal" id="modalGestionarFranja">
        <div style="position:relative;">
            <button class="modal-close" onclick="cerrarModal('modalGestionarFranja')">&#x2715;</button>
            <div class="modal-content">
                <div class="modal-header" id="gestionTitle">Gestionar Franja</div>
                <div style="margin-bottom:20px;">
                    <div class="section-subtitle">Socios asignados</div>
                    <div id="gestionsocios"><div class="empty-message">Cargando...</div></div>
                    <button class="btn btn-primary btn-sm" onclick="abrirBuscadorSocio()" style="margin-top:10px;">+ Agregar socio</button>
                </div>
                <hr style="border:none;border-top:1px solid var(--neutral-200);margin:16px 0;">
                <div>
                    <div class="section-subtitle">Instructores asignados</div>
                    <div id="gestioninstructores"><div class="empty-message">Cargando...</div></div>
                    <button class="btn btn-primary btn-sm" onclick="abrirBuscadorInstructor()" style="margin-top:10px;">+ Agregar instructor</button>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-top:20px;flex-wrap:wrap;gap:8px;">
                    <div style="display:flex;gap:6px;">
                        <button id="btnDividirCuartos" style="color:#94a3b8;border:1px solid var(--neutral-200);background:white;font-size:12px;padding:5px 10px;border-radius:6px;cursor:pointer;" onclick="dividirFranjaEnCuartos()">Dividir en cuartos</button>
                        <button id="btnReunirCuartos" style="display:none;color:#2563eb;border:1px solid #93c5fd;background:white;font-size:12px;padding:5px 10px;border-radius:6px;cursor:pointer;" onclick="reunirEnUnaHora()">Reunir en 1 hora</button>
                    </div>
                    <div style="display:flex;gap:8px;">
                        <button style="color:#ef4444;border:1px solid #fca5a5;background:white;font-size:12px;padding:5px 10px;border-radius:6px;cursor:pointer;" onclick="eliminarFranjaActual()">Eliminar franja</button>
                        <button class="btn btn-secondary" onclick="cerrarModal('modalGestionarFranja')">Cerrar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal: Buscar socio -->
    <div class="modal" id="modalBuscarSocio">
        <div style="position:relative;">
            <button class="modal-close" onclick="cerrarModal('modalBuscarSocio')">&#x2715;</button>
            <div class="modal-content">
                <div class="modal-header">Agregar Socio</div>
                <p class="search-hint">Buscar por apellido, nombre o DNI (minimo 2 caracteres)</p>
                <input type="text" id="inputBuscarSocio" class="search-input" placeholder="Ej: Garcia o 35123456" oninput="buscarSocios(this.value)">
                <div id="resultadosSocios" class="search-results">
                    <div style="padding:12px;color:var(--neutral-400);font-size:var(--text-sm);">Escriba para buscar...</div>
                </div>
                <div style="text-align:right;margin-top:16px;">
                    <button class="btn btn-secondary" onclick="cerrarModal('modalBuscarSocio')">Cancelar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal: Buscar instructor -->
    <div class="modal" id="modalBuscarInstructor">
        <div style="position:relative;">
            <button class="modal-close" onclick="cerrarModal('modalBuscarInstructor')">&#x2715;</button>
            <div class="modal-content">
                <div class="modal-header">Agregar Instructor</div>
                <div id="listaInstructoresDisponibles" class="search-results" style="max-height:320px;">
                    <div style="padding:12px;color:var(--neutral-400);">Cargando...</div>
                </div>
                <div style="text-align:right;margin-top:16px;">
                    <button class="btn btn-secondary" onclick="cerrarModal('modalBuscarInstructor')">Cancelar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal: Nueva actividad -->
    <div class="modal" id="modalNuevaActividad">
        <div style="position:relative;">
            <button class="modal-close" onclick="cerrarModal('modalNuevaActividad')">&#x2715;</button>
            <div class="modal-content">
                <div class="modal-header">Nueva Actividad</div>
                <div class="form-group">
                    <label>Nombre *</label>
                    <input type="text" id="nuevaActNombre" placeholder="Ej: Natacion, Tenis...">
                </div>
                <div class="form-group">
                    <label>Descripcion</label>
                    <input type="text" id="nuevaActDescripcion" placeholder="Descripcion breve">
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="form-group">
                        <label>Precio base ($)</label>
                        <input type="number" id="nuevaActPrecio" placeholder="0" min="0">
                    </div>
                    <div class="form-group" style="display:flex;align-items:flex-end;padding-bottom:4px;">
                        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:normal;">
                            <input type="checkbox" id="nuevaActFlexible"> Horario flexible
                        </label>
                    </div>
                </div>
                <div style="display:flex;gap:8px;justify-content:flex-end;">
                    <button class="btn btn-secondary" onclick="cerrarModal('modalNuevaActividad')">Cancelar</button>
                    <button class="btn btn-primary" onclick="confirmarNuevaActividad()">Crear</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal: Plantilla horaria -->
    <div class="modal" id="modalPlantilla">
        <div style="position:relative;">
            <button class="modal-close" onclick="cerrarModal('modalPlantilla')">&#x2715;</button>
            <div class="modal-content">
                <div class="modal-header" id="plantillaTitulo">Plantilla</div>
                <p style="color:var(--neutral-500);font-size:var(--text-sm);margin-bottom:20px;">
                    Dias: <strong id="plantillaDiasTexto"></strong>
                </p>
                <input type="hidden" id="plantillaIdxInput">
                <div class="form-group">
                    <label>Hora de inicio</label>
                    <select id="plantillaHoraInicio"></select>
                </div>
                <div class="form-group">
                    <label>Duracion</label>
                    <select id="plantillaDuracion">
                        <option value="1">1 hora</option>
                        <option value="2">2 horas</option>
                        <option value="3">3 horas</option>
                    </select>
                </div>
                <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:20px;">
                    <button class="btn btn-secondary" onclick="cerrarModal('modalPlantilla')">Cancelar</button>
                    <button class="btn btn-primary" onclick="confirmarPlantilla()">Aplicar plantilla</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        var allActividades = [];
        var actividadActual = null;
        var franjaActual = null;
        var buscarTimeout = null;
        var filtroActual = 'todos';
        var diasNombre = ['LUNES', 'MARTES', 'MIERCOLES', 'JUEVES', 'VIERNES', 'SABADO', 'DOMINGO'];
        var diasCorto = ['Lun', 'Mar', 'Mie', 'Jue', 'Vie', 'Sab', 'Dom'];
        var HORA_INICIO = 7;
        var HORA_FIN = 21;

        var iconMap = [
            ['natacion','🏊'],['natación','🏊'],['pileta','🏊'],
            ['futbol','⚽'],['fútbol','⚽'],['football','⚽'],
            ['tenis','🎾'],['padel','🎾'],['pádel','🎾'],
            ['yoga','🧘'],['meditacion','🧘'],
            ['musculacion','💪'],['musculación','💪'],['muscu','💪'],['pesas','💪'],['gym','💪'],['fitness','💪'],
            ['pilates','🤸'],['gimnasia','🤸'],['aerobics','🤸'],['zumba','🤸'],
            ['hockey','🏑'],['basquet','🏀'],['básquet','🏀'],['basket','🏀'],
            ['voley','🏐'],['vóley','🏐'],['voleibol','🏐'],
            ['boxeo','🥊'],['karate','🥋'],['artes marciales','🥋'],['judo','🥋'],
            ['ciclismo','🚴'],['bici','🚴'],['running','🏃'],['atletismo','🏃'],
            ['baile','💃'],['danza','💃'],['ajedrez','♟️'],['esgrima','🤺']
        ];
        var iconColors = ['#e8f5e9','#e3f2fd','#fce4ec','#fff3e0','#f3e5f5','#e0f2f1','#fefce8'];

        var PLANTILLAS = [
            { nombre: 'Lun-Mie-Vie', dias: [0, 2, 4] },
            { nombre: 'Mar-Jue', dias: [1, 3] },
            { nombre: 'Lun a Vie', dias: [0, 1, 2, 3, 4] },
            { nombre: 'Fin de semana', dias: [5, 6] },
            { nombre: 'Todos los dias', dias: [0, 1, 2, 3, 4, 5, 6] }
        ];

        function getActIcon(nombre) {
            var lower = nombre.toLowerCase();
            for (var k = 0; k < iconMap.length; k++) {
                if (lower.includes(iconMap[k][0])) return iconMap[k][1];
            }
            return '🏃';
        }
        function getActColor(id) { return iconColors[id % iconColors.length]; }

        function cerrarModal(id) { document.getElementById(id).classList.remove('active'); }

        // ─── LISTA DE ACTIVIDADES ────────────────────────────────────────────

        async function cargarActividades() {
            try {
                var r = await fetch('/api/actividades', { credentials: 'include' });
                var d = await r.json();
                if (d.success) {
                    allActividades = d.actividades || [];
                    renderLista();
                }
            } catch(err) {
                document.getElementById('listaActividades').innerHTML = '<div style="color:red;padding:20px;">Error al cargar actividades</div>';
            }
        }

        function setFiltro(filtro, btn) {
            filtroActual = filtro;
            document.querySelectorAll('.filtro-pill').forEach(function(p) { p.classList.remove('activo'); });
            btn.classList.add('activo');
            renderLista();
        }

        function filtrarActividades() { renderLista(); }

        function getActividadesFiltradas() {
            var q = (document.getElementById('busquedaActividades') ? document.getElementById('busquedaActividades').value : '').toLowerCase().trim();
            return allActividades.filter(function(act) {
                var matchQ = !q || act.nombre.toLowerCase().includes(q) || (act.descripcion || '').toLowerCase().includes(q);
                var matchF = filtroActual === 'todos' ||
                    (filtroActual === 'franjas' && !act.tiene_horarios_flexibles) ||
                    (filtroActual === 'flexibles' && act.tiene_horarios_flexibles);
                return matchQ && matchF;
            });
        }

        function renderLista() {
            var container = document.getElementById('listaActividades');
            if (allActividades.length === 0) {
                container.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:60px;color:#94a3b8;">Cargando...</div>';
                return;
            }
            var actividades = getActividadesFiltradas();
            if (actividades.length === 0) {
                container.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:60px;color:#94a3b8;">No hay actividades que coincidan.</div>';
                return;
            }
            var html = '';
            actividades.forEach(function(act) {
                var franjas = act.franjas || [];
                var totalFranjas = franjas.length;
                var totalSocios = 0;
                franjas.forEach(function(f) { totalSocios += (f.socios_count || 0); });

                var footerInfo = act.tiene_horarios_flexibles
                    ? (act.socios_count || 0) + ' socios inscriptos'
                    : totalFranjas + ' franjas &middot; ' + totalSocios + ' socios';

                var icon = getActIcon(act.nombre);
                var color = getActColor(act.id);

                var instructoresHtml = '';
                if (act.instructores && act.instructores.length > 0) {
                    act.instructores.forEach(function(i) {
                        instructoresHtml += '<span style="background:#e8f5e9;color:var(--primary);font-size:11px;font-weight:700;padding:2px 8px;border-radius:20px;">' + i.apellido + ', ' + i.nombre + '</span>';
                    });
                } else {
                    instructoresHtml = '<span style="color:var(--neutral-400);font-size:11px;">Sin instructor asignado</span>';
                }

                html += '<div class="act-card-v2" onclick="abrirDetalle(' + act.id + ')">' +
                    '<div class="act-icon-wrap" style="background:' + color + ';">' + icon + '</div>' +
                    '<div class="act-card-v2-nombre">' + act.nombre + '</div>' +
                    '<div class="act-card-v2-desc">' + (act.descripcion || '') + '</div>' +
                    '<div class="act-card-v2-instructores">' + instructoresHtml + '</div>' +
                    '<div class="act-card-v2-footer">' +
                        '<span>' + footerInfo + '</span>' +
                        '<span class="act-gestionar">Gestionar &#8594;</span>' +
                    '</div>' +
                    '</div>';
            });
            container.innerHTML = html;
        }

        // ─── VISTA DETALLE / GRILLA ──────────────────────────────────────────

        async function abrirDetalle(actividadId) {
            actividadActual = actividadId;
            var act = allActividades.find(function(a) { return a.id === actividadId; });
            if (!act) return;

            document.getElementById('detalleNombre').textContent = act.nombre;
            document.getElementById('detalleDesc').textContent = act.descripcion || '';
            document.getElementById('vistaLista').style.display = 'none';
            document.getElementById('vistaDetalle').style.display = 'block';

            renderGrilla(act);
        }

        function volverALista() {
            document.getElementById('vistaDetalle').style.display = 'none';
            document.getElementById('vistaLista').style.display = 'block';
            actividadActual = null;
        }

        function horaToStr(h) {
            var horas = Math.floor(h);
            var mins = Math.round((h - horas) * 60);
            return (horas < 10 ? '0' + horas : '' + horas) + ':' + (mins < 10 ? '0' + mins : '' + mins);
        }

        function renderGrilla(act) {
            var franjas = act.franjas || [];

            // Agrupar por dia-baseHora (para detectar cuartos)
            var franjaGroups = {};
            franjas.forEach(function(f) {
                var baseHora = Math.floor(f.hora_inicio);
                var key = f.dia_semana + '-' + baseHora;
                if (!franjaGroups[key]) franjaGroups[key] = [];
                franjaGroups[key].push(f);
            });

            var html = '';
            html += '<div class="grilla-header"></div>';
            for (var d = 0; d < 7; d++) {
                html += '<div class="grilla-header">' + diasCorto[d] + '</div>';
            }

            for (var h = HORA_INICIO; h < HORA_FIN; h++) {
                html += '<div class="grilla-hora">' + horaToStr(h) + '</div>';
                for (var dia = 0; dia < 7; dia++) {
                    var key = dia + '-' + h;
                    var grupo = franjaGroups[key] || [];

                    if (grupo.length === 0) {
                        html += '<div class="grilla-slot vacio" data-dia="' + dia + '" data-hora="' + h + '"' +
                            ' onmousedown="startDrag(event,' + dia + ',' + h + ')"' +
                            ' onmouseenter="onDragEnter(' + dia + ',' + h + ')"' +
                            ' title="Agregar ' + diasNombre[dia] + ' ' + horaToStr(h) + '">+</div>';
                    } else if (grupo.length === 1 && grupo[0].hora_inicio === h) {
                        var f = grupo[0];
                        var socios = f.socios_count || 0;
                        var profes = f.instructores_count || 0;
                        html += '<div class="grilla-slot ocupado" onclick="abrirGestionFranja(' + f.id + ',' + act.id + ',' + dia + ',' + h + ')">' +
                            '<div class="slot-count">' + socios + ' socios</div>' +
                            (profes > 0 ? '<div class="slot-sub">' + profes + ' prof</div>' : '') +
                            '</div>';
                    } else {
                        // Celda subdividida
                        html += renderCeldaSubdividida(grupo, act.id, dia, h);
                    }
                }
            }

            document.getElementById('grillaHoraria').innerHTML = html;
        }

        function renderCeldaSubdividida(grupo, actId, dia, baseHora) {
            var quarters = [0, 0.25, 0.5, 0.75];
            var inner = '';
            quarters.forEach(function(q) {
                var targetHora = baseHora + q;
                var franja = null;
                for (var i = 0; i < grupo.length; i++) {
                    if (Math.abs(grupo[i].hora_inicio - targetHora) < 0.01) { franja = grupo[i]; break; }
                }
                var label = ':' + (q === 0 ? '00' : q === 0.25 ? '15' : q === 0.5 ? '30' : '45');
                if (franja) {
                    inner += '<div class="quarter-slot ocupado" onclick="abrirGestionFranja(' + franja.id + ',' + actId + ',' + dia + ',' + targetHora + ')">' +
                        label + '<br>' + (franja.socios_count || 0) + '</div>';
                } else {
                    inner += '<div class="quarter-slot vacio" onmousedown="crearFranjaDecimal(event,' + actId + ',' + dia + ',' + targetHora + ')">' + label + '</div>';
                }
            });
            return '<div class="grilla-slot subdividida">' + inner + '</div>';
        }

        // ─── DRAG TO PAINT ───────────────────────────────────────────────────

        var isDragging = false;
        var dragDia = -1;
        var dragStartHora = -1;
        var dragEndHora = -1;

        function startDrag(e, dia, hora) {
            if (e.button !== 0) return;
            e.preventDefault();
            isDragging = true;
            dragDia = dia;
            dragStartHora = hora;
            dragEndHora = hora;
        }

        function onDragEnter(dia, hora) {
            if (!isDragging || dia !== dragDia) return;
            dragEndHora = hora;
            actualizarVisualDrag();
        }

        function actualizarVisualDrag() {
            var min = Math.min(dragStartHora, dragEndHora);
            var max = Math.max(dragStartHora, dragEndHora);
            document.querySelectorAll('.grilla-slot.vacio').forEach(function(cell) {
                var cellDia = parseInt(cell.dataset.dia);
                var cellHora = parseInt(cell.dataset.hora);
                if (cellDia === dragDia && cellHora >= min && cellHora <= max) {
                    cell.classList.add('seleccionado');
                } else {
                    cell.classList.remove('seleccionado');
                }
            });
        }

        function onGridMouseMove(e) {
            if (!isDragging) return;
            var target = e.target;
            while (target && target.id !== 'grillaHoraria') {
                if (target.classList && target.classList.contains('grilla-slot') && target.classList.contains('vacio')) {
                    var dia = parseInt(target.dataset.dia);
                    var hora = parseInt(target.dataset.hora);
                    if (!isNaN(dia) && !isNaN(hora) && dia === dragDia && hora !== dragEndHora) {
                        dragEndHora = hora;
                        actualizarVisualDrag();
                    }
                    return;
                }
                target = target.parentElement;
            }
        }

        function cancelDragVisual() {
            document.querySelectorAll('.seleccionado').forEach(function(c) { c.classList.remove('seleccionado'); });
        }

        document.addEventListener('mouseup', async function() {
            if (!isDragging) return;
            isDragging = false;
            document.querySelectorAll('.seleccionado').forEach(function(c) { c.classList.remove('seleccionado'); });

            if (dragDia < 0 || dragStartHora < 0) return;
            var min = Math.min(dragStartHora, dragEndHora);
            var max = Math.max(dragStartHora, dragEndHora);
            var horas = [];
            for (var h = min; h <= max; h++) horas.push(h);

            var d = dragDia; var actId = actividadActual;
            dragDia = -1; dragStartHora = -1; dragEndHora = -1;

            if (!actId) return;
            if (horas.length === 1) {
                await crearFranjaRaw(actId, d, horas[0], horas[0] + 1);
            } else {
                if (!confirm('Crear ' + horas.length + ' franjas de 1 hora (' + horaToStr(min) + ' a ' + horaToStr(max + 1) + ')?')) return;
                await Promise.all(horas.map(function(h) { return crearFranjaRaw(actId, d, h, h + 1); }));
            }
            await recargarActividadActual();
        });

        async function crearFranjaRaw(actividadId, dia, horaInicio, horaFin) {
            try {
                var r = await fetch('/api/actividades/' + actividadId + '/franjas', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ dia_semana: dia, hora_inicio: horaInicio, hora_fin: horaFin })
                });
                return await r.json();
            } catch(err) { return { success: false }; }
        }

        async function crearFranjaDecimal(e, actividadId, dia, horaInicio) {
            e.preventDefault(); e.stopPropagation();
            await crearFranjaRaw(actividadId, dia, horaInicio, horaInicio + 0.25);
            await recargarActividadActual();
        }

        // ─── GESTIONAR FRANJA ────────────────────────────────────────────────

        var franjaBaseHora = -1;
        var franjaDiaSemana = -1;

        async function abrirGestionFranja(franjaId, actividadId, dia, hora) {
            franjaActual = franjaId;
            actividadActual = actividadId;
            franjaBaseHora = Math.floor(hora);
            franjaDiaSemana = dia;
            var esSubdividida = (hora !== Math.floor(hora));
            document.getElementById('btnDividirCuartos').style.display = esSubdividida ? 'none' : 'inline-block';
            document.getElementById('btnReunirCuartos').style.display = esSubdividida ? 'inline-block' : 'none';
            var act = allActividades.find(function(a) { return a.id === actividadId; });
            var titulo = (act ? act.nombre : '') + ' — ' + diasNombre[dia] + ' ' + horaToStr(hora);
            document.getElementById('gestionTitle').textContent = titulo;
            document.getElementById('gestionsocios').innerHTML = '<div class="empty-message">Cargando...</div>';
            document.getElementById('gestioninstructores').innerHTML = '<div class="empty-message">Cargando...</div>';
            document.getElementById('modalGestionarFranja').classList.add('active');
            await cargarDetallesFranja();
        }

        async function cargarDetallesFranja() {
            try {
                var r = await fetch('/api/franjas/' + franjaActual, { credentials: 'include' });
                var d = await r.json();
                if (!d.success) return;

                var sociosHtml = '';
                if (!d.socios || d.socios.length === 0) {
                    sociosHtml = '<div class="empty-message">Sin socios asignados</div>';
                } else {
                    d.socios.forEach(function(s) {
                        sociosHtml += '<div class="persona-item"><span>' + s.apellido + ', ' + s.nombre + '</span><button class="remove-btn" onclick="quitarSocio(' + franjaActual + ',' + s.id + ')">&#x2715;</button></div>';
                    });
                }
                document.getElementById('gestionsocios').innerHTML = sociosHtml;

                var instructoresHtml = '';
                if (!d.instructores || d.instructores.length === 0) {
                    instructoresHtml = '<div class="empty-message">Sin instructores asignados</div>';
                } else {
                    d.instructores.forEach(function(i) {
                        instructoresHtml += '<div class="persona-item"><span>' + i.apellido + ', ' + i.nombre + '</span><button class="remove-btn" onclick="quitarInstructor(' + franjaActual + ',' + i.id + ')">&#x2715;</button></div>';
                    });
                }
                document.getElementById('gestioninstructores').innerHTML = instructoresHtml;
            } catch(err) { console.error(err); }
        }

        // ─── SOCIOS ──────────────────────────────────────────────────────────

        function abrirBuscadorSocio() {
            document.getElementById('inputBuscarSocio').value = '';
            document.getElementById('resultadosSocios').innerHTML = '<div style="padding:12px;color:var(--neutral-400);">Escriba para buscar...</div>';
            document.getElementById('modalBuscarSocio').classList.add('active');
            setTimeout(function() { document.getElementById('inputBuscarSocio').focus(); }, 100);
        }

        function buscarSocios(texto) {
            clearTimeout(buscarTimeout);
            if (texto.length < 2) {
                document.getElementById('resultadosSocios').innerHTML = '<div style="padding:12px;color:var(--neutral-400);">Escriba al menos 2 caracteres...</div>';
                return;
            }
            document.getElementById('resultadosSocios').innerHTML = '<div style="padding:12px;color:var(--neutral-400);">Buscando...</div>';
            buscarTimeout = setTimeout(async function() {
                try {
                    var r = await fetch('/api/franjas/' + franjaActual + '/socios/disponibles?q=' + encodeURIComponent(texto), { credentials: 'include' });
                    var d = await r.json();
                    if (!d.success) return;
                    if (d.socios.length === 0) {
                        document.getElementById('resultadosSocios').innerHTML = '<div style="padding:12px;color:var(--neutral-400);">Sin resultados</div>';
                        return;
                    }
                    var html = '';
                    d.socios.forEach(function(s) {
                        html += '<div class="search-result-item" onclick="seleccionarSocio(' + s.id + ')">' +
                            '<strong>' + s.apellido + ', ' + s.nombre + '</strong>' +
                            '<span style="margin-left:8px;opacity:0.6;font-size:11px;">DNI ' + (s.dni || '-') + '</span>' +
                            '</div>';
                    });
                    document.getElementById('resultadosSocios').innerHTML = html;
                } catch(err) { console.error(err); }
            }, 300);
        }

        async function seleccionarSocio(socioId) {
            try {
                var r = await fetch('/api/franjas/' + franjaActual + '/socios', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    credentials: 'include', body: JSON.stringify({ socio_id: socioId })
                });
                var d = await r.json();
                if (d.success) {
                    cerrarModal('modalBuscarSocio');
                    await cargarDetallesFranja();
                    await recargarActividadActual();
                } else alert('Error: ' + d.error);
            } catch(err) { alert('Error: ' + err.message); }
        }

        async function quitarSocio(franjaId, socioId) {
            if (!confirm('Quitar este socio de la franja?')) return;
            var r = await fetch('/api/franjas/' + franjaId + '/socios/' + socioId, { method: 'DELETE', credentials: 'include' });
            var d = await r.json();
            if (d.success) { await cargarDetallesFranja(); await recargarActividadActual(); }
            else alert('Error: ' + d.error);
        }

        // ─── INSTRUCTORES ─────────────────────────────────────────────────────

        async function abrirBuscadorInstructor() {
            document.getElementById('listaInstructoresDisponibles').innerHTML = '<div style="padding:12px;color:var(--neutral-400);">Cargando...</div>';
            document.getElementById('modalBuscarInstructor').classList.add('active');
            var r = await fetch('/api/franjas/' + franjaActual + '/instructores/disponibles', { credentials: 'include' });
            var d = await r.json();
            if (!d.success) return;
            if (d.instructores.length === 0) {
                document.getElementById('listaInstructoresDisponibles').innerHTML = '<div style="padding:12px;color:var(--neutral-400);">Todos los instructores ya estan asignados</div>';
                return;
            }
            var html = '';
            d.instructores.forEach(function(i) {
                html += '<div class="search-result-item" onclick="seleccionarInstructor(' + i.id + ')">' + i.apellido + ', ' + i.nombre + '</div>';
            });
            document.getElementById('listaInstructoresDisponibles').innerHTML = html;
        }

        async function seleccionarInstructor(instructorId) {
            var r = await fetch('/api/franjas/' + franjaActual + '/instructores', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                credentials: 'include', body: JSON.stringify({ instructor_id: instructorId })
            });
            var d = await r.json();
            if (d.success) { cerrarModal('modalBuscarInstructor'); await cargarDetallesFranja(); await recargarActividadActual(); }
            else alert('Error: ' + d.error);
        }

        async function quitarInstructor(franjaId, instructorId) {
            if (!confirm('Quitar este instructor de la franja?')) return;
            var r = await fetch('/api/franjas/' + franjaId + '/instructores/' + instructorId, { method: 'DELETE', credentials: 'include' });
            var d = await r.json();
            if (d.success) { await cargarDetallesFranja(); await recargarActividadActual(); }
            else alert('Error: ' + d.error);
        }

        // ─── NUEVA ACTIVIDAD ──────────────────────────────────────────────────

        function abrirModalNuevaActividad() {
            document.getElementById('nuevaActNombre').value = '';
            document.getElementById('nuevaActDescripcion').value = '';
            document.getElementById('nuevaActPrecio').value = '';
            document.getElementById('nuevaActFlexible').checked = false;
            document.getElementById('modalNuevaActividad').classList.add('active');
        }

        async function confirmarNuevaActividad() {
            var nombre = document.getElementById('nuevaActNombre').value.trim();
            if (!nombre) { alert('El nombre es requerido'); return; }
            var r = await fetch('/api/actividades', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    nombre: nombre,
                    descripcion: document.getElementById('nuevaActDescripcion').value.trim(),
                    precio_base: parseFloat(document.getElementById('nuevaActPrecio').value) || 0,
                    tiene_horarios_flexibles: document.getElementById('nuevaActFlexible').checked ? 1 : 0
                })
            });
            var d = await r.json();
            if (d.success) { cerrarModal('modalNuevaActividad'); await cargarActividades(); }
            else alert('Error: ' + d.error);
        }

        // ─── ELIMINAR FRANJA / DIVIDIR EN CUARTOS / ELIMINAR ACTIVIDAD ──────

        async function eliminarFranjaActual() {
            if (!confirm('Eliminar esta franja? Se perderan los socios e instructores asignados.')) return;
            try {
                var r = await fetch('/api/franjas/' + franjaActual, { method: 'DELETE', credentials: 'include' });
                var d = await r.json();
                if (d.success) {
                    cerrarModal('modalGestionarFranja');
                    await recargarActividadActual();
                } else alert('Error: ' + d.error);
            } catch(err) { alert('Error: ' + err.message); }
        }

        async function dividirFranjaEnCuartos() {
            try {
                var r = await fetch('/api/franjas/' + franjaActual, { credentials: 'include' });
                var d = await r.json();
                if (!d.success) return;
                var f = d.franja;
                var baseHora = Math.floor(f.hora_inicio);

                var aviso = d.socios && d.socios.length > 0
                    ? 'Esta franja tiene ' + d.socios.length + ' socio(s). Al dividir perderan su asignacion. '
                    : '';
                if (!confirm(aviso + 'Dividir en 4 cuartos de 15 min?')) return;

                var quarters = [0, 0.25, 0.5, 0.75];
                await Promise.all(quarters.map(function(q) {
                    return fetch('/api/actividades/' + actividadActual + '/franjas', {
                        method: 'POST', headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ dia_semana: f.dia_semana, hora_inicio: baseHora + q, hora_fin: baseHora + q + 0.25 })
                    });
                }));
                await fetch('/api/franjas/' + franjaActual, { method: 'DELETE', credentials: 'include' });
                cerrarModal('modalGestionarFranja');
                await recargarActividadActual();
            } catch(err) { alert('Error: ' + err.message); }
        }

        async function reunirEnUnaHora() {
            var act = allActividades.find(function(a) { return a.id === actividadActual; });
            if (!act) return;
            var cuartos = (act.franjas || []).filter(function(f) {
                return f.dia_semana === franjaDiaSemana && Math.floor(f.hora_inicio) === franjaBaseHora;
            });
            var totalSocios = cuartos.reduce(function(s, f) { return s + (f.socios_count || 0); }, 0);
            var aviso = totalSocios > 0 ? totalSocios + ' socios perderan su asignacion. ' : '';
            if (!confirm(aviso + 'Reunir todos los cuartos de las ' + horaToStr(franjaBaseHora) + ' en una franja de 1 hora?')) return;
            try {
                await Promise.all(cuartos.map(function(f) {
                    return fetch('/api/franjas/' + f.id, { method: 'DELETE', credentials: 'include' });
                }));
                await fetch('/api/actividades/' + actividadActual + '/franjas', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ dia_semana: franjaDiaSemana, hora_inicio: franjaBaseHora, hora_fin: franjaBaseHora + 1 })
                });
                cerrarModal('modalGestionarFranja');
                await recargarActividadActual();
            } catch(err) { alert('Error: ' + err.message); }
        }

        async function eliminarActividadActual() {
            if (!confirm('Eliminar la actividad? Quedara archivada y no aparecera en la lista.')) return;
            try {
                var r = await fetch('/api/actividades/' + actividadActual, { method: 'DELETE', credentials: 'include' });
                var d = await r.json();
                if (d.success) { volverALista(); await cargarActividades(); }
                else alert('Error: ' + d.error);
            } catch(err) { alert('Error: ' + err.message); }
        }

        // ─── PLANTILLAS ──────────────────────────────────────────────────────

        function llenarHorasSelector() {
            var sel = document.getElementById('plantillaHoraInicio');
            if (sel.options.length > 0) return;
            for (var h = HORA_INICIO; h < HORA_FIN; h++) {
                var opt = document.createElement('option');
                opt.value = h;
                opt.textContent = (h < 10 ? '0' + h : h) + ':00';
                sel.appendChild(opt);
            }
        }

        function aplicarPlantilla(idx) {
            var p = PLANTILLAS[idx];
            document.getElementById('plantillaTitulo').textContent = 'Plantilla: ' + p.nombre;
            document.getElementById('plantillaDiasTexto').textContent = p.dias.map(function(d) { return diasCorto[d]; }).join(', ');
            document.getElementById('plantillaIdxInput').value = idx;
            llenarHorasSelector();
            document.getElementById('modalPlantilla').classList.add('active');
        }

        async function confirmarPlantilla() {
            var idx = parseInt(document.getElementById('plantillaIdxInput').value);
            var p = PLANTILLAS[idx];
            var horaInicio = parseInt(document.getElementById('plantillaHoraInicio').value);
            var duracion = parseInt(document.getElementById('plantillaDuracion').value);
            var horaFin = horaInicio + duracion;

            if (horaFin > HORA_FIN) {
                alert('El horario de fin supera las ' + HORA_FIN + ':00');
                return;
            }

            var act = allActividades.find(function(a) { return a.id === actividadActual; });
            var franjaMap = {};
            (act ? act.franjas || [] : []).forEach(function(f) {
                franjaMap[f.dia_semana + '-' + f.hora_inicio] = true;
            });

            var diasNuevos = p.dias.filter(function(d) { return !franjaMap[d + '-' + horaInicio]; });
            var diasExist = p.dias.filter(function(d) { return franjaMap[d + '-' + horaInicio]; });

            if (diasNuevos.length === 0) {
                alert('Ya existen franjas para todos los dias de esta plantilla en ese horario.');
                return;
            }
            if (diasExist.length > 0) {
                if (!confirm('Ya existe franja en ' + diasExist.map(function(d) { return diasCorto[d]; }).join(', ') + '. Se crean solo los dias disponibles. Continuar?')) return;
            }

            cerrarModal('modalPlantilla');
            try {
                await Promise.all(diasNuevos.map(function(dia) {
                    return fetch('/api/actividades/' + actividadActual + '/franjas', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ dia_semana: dia, hora_inicio: horaInicio, hora_fin: horaFin })
                    });
                }));
                await recargarActividadActual();
            } catch(err) { alert('Error: ' + err.message); }
        }

        // ─── HELPERS ─────────────────────────────────────────────────────────

        async function recargarActividadActual() {
            await cargarActividades();
            if (actividadActual) {
                var act = allActividades.find(function(a) { return a.id === actividadActual; });
                if (act) renderGrilla(act);
            }
        }

        cargarActividades();
    </script>
</body>
</html>
