<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Cuotas y Pagos — Club Médanos Verdes</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
    <style>
        /* Cuotas-specific overrides */
        .btn-primary { background: linear-gradient(135deg, var(--accent) 0%, var(--success) 100%); }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>💳 Cuotas y Pagos</h1>
            <p>Planes de cuota, generación mensual y registro de pagos</p>
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 15px;">
            <div class="tabs">
                <button class="tab active" onclick="mostrarTab('planes')">Planes</button>
                <button class="tab" onclick="mostrarTab('cuotas')">Cuotas</button>
            </div>
            <a href="/dashboard" class="btn btn-secondary">← Volver al dashboard</a>
        </div>

        <!-- TAB PLANES -->
        <div id="planes" class="tab-content active">
            <div class="top-bar">
                <button class="btn btn-primary" onclick="abrirModalPlan()">+ Nuevo plan</button>
            </div>
            <div class="content-card">
                <table id="planesTable">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Monto</th>
                            <th>Tipo</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="planesBody">
                        <tr><td colspan="5" class="empty-state">Cargando planes...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- TAB CUOTAS -->
        <div id="cuotas" class="tab-content">
            <div class="top-bar">
                <button class="btn btn-primary" onclick="generarCuotasDelMes()">🔄 Generar cuotas del mes</button>
            </div>
            <div class="content-card">
                <div style="margin-bottom: 20px;">
                    <select id="filterEstado" onchange="filtrarCuotas()" style="padding: 8px; border: 1px solid #e2e8f0; border-radius: 6px; font-family: 'DM Sans';">
                        <option value="">Todos los estados</option>
                        <option value="PENDIENTE">Pendiente</option>
                        <option value="PAGADA">Pagada</option>
                        <option value="VENCIDA">Vencida</option>
                    </select>
                </div>
                <table id="cuotasTable">
                    <thead>
                        <tr>
                            <th>Período</th>
                            <th>Socio</th>
                            <th>Monto</th>
                            <th>Estado</th>
                            <th>Vencimiento</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="cuotasBody">
                        <tr><td colspan="6" class="empty-state">Cargando cuotas...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal Plan -->
    <div class="modal" id="modalPlan">
        <div style="position: relative;">
            <button class="modal-close" onclick="cerrarModal('modalPlan')">✕</button>
            <div class="modal-content">
                <div class="modal-header">Nuevo plan de cuota</div>
                <form onsubmit="guardarPlan(event)">
                    <div class="form-group">
                        <label>Nombre *</label>
                        <input type="text" id="planNombre" required>
                    </div>
                    <div class="form-group">
                        <label>Descripción</label>
                        <textarea id="planDescripcion" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Monto *</label>
                        <input type="number" id="planMonto" step="0.01" required>
                    </div>
                    <div class="form-group">
                        <label>Tipo</label>
                        <select id="planTipo">
                            <option value="">Ninguno</option>
                            <option value="individual">Individual</option>
                            <option value="familiar">Familiar</option>
                            <option value="actividad">Por actividad</option>
                            <option value="combo">Combo</option>
                        </select>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn-submit">Guardar</button>
                        <button type="button" class="btn-cancel" onclick="cerrarModal('modalPlan')">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Pago -->
    <div class="modal" id="modalPago">
        <div style="position: relative;">
            <button class="modal-close" onclick="cerrarModal('modalPago')">✕</button>
            <div class="modal-content">
                <div class="modal-header">Registrar pago</div>
                <form onsubmit="guardarPago(event)">
                    <input type="hidden" id="pagoId">
                    <div class="form-group">
                        <label>Importe *</label>
                        <input type="number" id="pagoImporte" step="0.01" required>
                    </div>
                    <div class="form-group">
                        <label>Medio de pago</label>
                        <select id="pagoMedio">
                            <option value="efectivo">Efectivo</option>
                            <option value="transferencia">Transferencia</option>
                            <option value="debito">Débito</option>
                            <option value="otro">Otro</option>
                        </select>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn-submit">Registrar pago</button>
                        <button type="button" class="btn-cancel" onclick="cerrarModal('modalPago')">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        let allPlanes = [];
        let allCuotas = [];

        function mostrarTab(tab) {
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.getElementById(tab).classList.add('active');
            event.target.classList.add('active');
            if (tab === 'planes') cargarPlanes();
            else cargarCuotas();
        }

        async function cargarPlanes() {
            try {
                const r = await fetch('/api/planes', { credentials: 'include' });
                const d = await r.json();
                if (d.success) {
                    allPlanes = d.planes || [];
                    renderPlanes();
                }
            } catch (err) { console.error(err); }
        }

        async function cargarCuotas() {
            try {
                const r = await fetch('/api/cuotas', { credentials: 'include' });
                const d = await r.json();
                if (d.success) {
                    allCuotas = d.cuotas || [];
                    renderCuotas();
                }
            } catch (err) { console.error(err); }
        }

        function renderPlanes() {
            const body = document.getElementById('planesBody');
            if (allPlanes.length === 0) {
                body.innerHTML = '<tr><td colspan="5" class="empty-state">No hay planes</td></tr>';
                return;
            }
            body.innerHTML = allPlanes.map(p => `
                <tr>
                    <td>${p.nombre}</td>
                    <td>${p.descripcion || '—'}</td>
                    <td>$${p.monto.toFixed(2)}</td>
                    <td>${p.tipo || '—'}</td>
                    <td><button class="btn-action" onclick="alert('Editar plan - Próximamente')">Editar</button></td>
                </tr>
            `).join('');
        }

        function renderCuotas() {
            const body = document.getElementById('cuotasBody');
            if (allCuotas.length === 0) {
                body.innerHTML = '<tr><td colspan="6" class="empty-state">No hay cuotas</td></tr>';
                return;
            }
            body.innerHTML = allCuotas.map(c => `
                <tr>
                    <td>${c.periodo}</td>
                    <td>${c.apellido}, ${c.nombre}</td>
                    <td>$${c.monto_total.toFixed(2)}</td>
                    <td><span class="badge badge-${c.estado.toLowerCase()}">${c.estado}</span></td>
                    <td>${c.fecha_vencimiento || '—'}</td>
                    <td>
                        ${c.estado === 'PENDIENTE' ? `<button class="btn-action" onclick="abrirModalPago(${c.id})">Pagar</button>` : '—'}
                    </td>
                </tr>
            `).join('');
        }

        function filtrarCuotas() {
            const estado = document.getElementById('filterEstado').value;
            const filtered = !estado ? allCuotas : allCuotas.filter(c => c.estado === estado);
            const body = document.getElementById('cuotasBody');
            if (filtered.length === 0) {
                body.innerHTML = '<tr><td colspan="6" class="empty-state">No hay cuotas</td></tr>';
                return;
            }
            body.innerHTML = filtered.map(c => `
                <tr>
                    <td>${c.periodo}</td>
                    <td>${c.apellido}, ${c.nombre}</td>
                    <td>$${c.monto_total.toFixed(2)}</td>
                    <td><span class="badge badge-${c.estado.toLowerCase()}">${c.estado}</span></td>
                    <td>${c.fecha_vencimiento || '—'}</td>
                    <td>
                        ${c.estado === 'PENDIENTE' ? `<button class="btn-action" onclick="abrirModalPago(${c.id})">Pagar</button>` : '—'}
                    </td>
                </tr>
            `).join('');
        }

        function abrirModalPlan() {
            document.getElementById('planNombre').value = '';
            document.getElementById('planDescripcion').value = '';
            document.getElementById('planMonto').value = '';
            document.getElementById('planTipo').value = '';
            document.getElementById('modalPlan').classList.add('active');
        }

        function abrirModalPago(cuotaId) {
            document.getElementById('pagoId').value = cuotaId;
            document.getElementById('pagoImporte').value = '';
            document.getElementById('pagoMedio').value = 'efectivo';
            document.getElementById('modalPago').classList.add('active');
        }

        function cerrarModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        async function guardarPlan(e) {
            e.preventDefault();
            const nombre = document.getElementById('planNombre').value;
            const descripcion = document.getElementById('planDescripcion').value;
            const monto = parseFloat(document.getElementById('planMonto').value);
            const tipo = document.getElementById('planTipo').value;

            try {
                const r = await fetch('/api/planes', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ nombre, descripcion, monto, tipo: tipo || null })
                });
                const d = await r.json();
                if (d.success) {
                    cerrarModal('modalPlan');
                    cargarPlanes();
                } else {
                    alert('Error: ' + d.error);
                }
            } catch (err) { alert('Error: ' + err.message); }
        }

        async function guardarPago(e) {
            e.preventDefault();
            const cuota_id = parseInt(document.getElementById('pagoId').value);
            const importe = parseFloat(document.getElementById('pagoImporte').value);
            const medio_pago = document.getElementById('pagoMedio').value;

            try {
                const r = await fetch('/api/pagos', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ cuota_id, importe, medio_pago })
                });
                const d = await r.json();
                if (d.success) {
                    cerrarModal('modalPago');
                    cargarCuotas();
                } else {
                    alert('Error: ' + d.error);
                }
            } catch (err) { alert('Error: ' + err.message); }
        }

        async function generarCuotasDelMes() {
            if (!confirm('¿Generar cuotas del mes actual para todos los socios activos?')) return;
            try {
                const r = await fetch('/api/cuotas/generar', { method: 'POST', credentials: 'include' });
                const d = await r.json();
                if (d.success) {
                    alert(d.message);
                    cargarCuotas();
                } else {
                    alert('Error: ' + d.error);
                }
            } catch (err) { alert('Error: ' + err.message); }
        }

        cargarPlanes();
    </script>
</body>
</html>
