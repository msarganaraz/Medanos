<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Usuarios — Admin — Club Médanos Verdes</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
    <style>
        .btn-delete { background: #ef4444; color: white; }
        .btn-delete:hover { background: #dc2626; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>⚙️ Administración de Usuarios</h1>
            <p>Crear, editar y gestionar usuarios del sistema</p>
        </div>

        <div class="top-bar">
            <button class="btn btn-primary" onclick="abrirModalCrear()">+ Nuevo usuario</button>
            <a href="/dashboard" class="btn btn-secondary">← Volver al dashboard</a>
        </div>

        <div class="content-card">
            <div class="search-bar">
                <input type="text" id="searchInput" placeholder="Buscar por nombre o usuario..." onkeyup="filtrarUsuarios()">
            </div>

            <table id="usuariosTable">
                <thead>
                    <tr>
                        <th>Usuario</th>
                        <th>Nombre</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody id="usuariosBody">
                    <tr><td colspan="5" class="empty-state">Cargando usuarios...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal Crear/Editar -->
    <div class="modal" id="modalUsuario">
        <div style="position: relative;">
            <button class="modal-close" onclick="cerrarModal('modalUsuario')">✕</button>
            <div class="modal-content">
                <div class="modal-header" id="modalTitle">Nuevo usuario</div>
                <form id="usuarioForm" onsubmit="guardarUsuario(event)">
                    <div class="form-group">
                        <label>Usuario *</label>
                        <input type="text" id="username" placeholder="ej: jgarcia" required>
                    </div>
                    <div class="form-group">
                        <label>Nombre completo *</label>
                        <input type="text" id="nombre" placeholder="ej: Juan García" required>
                    </div>
                    <div class="form-group">
                        <label>Rol *</label>
                        <select id="rol" required>
                            <option value="">Seleccionar...</option>
                            <option value="admin">Administrador</option>
                            <option value="recepcion">Recepción</option>
                            <option value="tesoreria">Tesorería</option>
                            <option value="instructor">Instructor</option>
                        </select>
                    </div>
                    <div class="form-group" id="passwordGroup">
                        <label>Contraseña *</label>
                        <input type="password" id="password" placeholder="••••••••" required>
                    </div>
                    <div class="form-group">
                        <label>
                            <input type="checkbox" id="activo" checked> Activo
                        </label>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn-submit">Guardar</button>
                        <button type="button" class="btn-cancel" onclick="cerrarModal('modalUsuario')">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Cambiar contraseña -->
    <div class="modal" id="modalPassword">
        <div style="position: relative;">
            <button class="modal-close" onclick="cerrarModal('modalPassword')">✕</button>
            <div class="modal-content">
                <div class="modal-header">Cambiar contraseña</div>
                <form id="passwordForm" onsubmit="cambiarContraseña(event)">
                    <div class="form-group">
                        <label>Contraseña actual *</label>
                        <input type="password" id="passwordActual" placeholder="••••••••" required>
                    </div>
                    <div class="form-group">
                        <label>Contraseña nueva *</label>
                        <input type="password" id="passwordNueva" placeholder="••••••••" required>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn-submit">Actualizar</button>
                        <button type="button" class="btn-cancel" onclick="cerrarModal('modalPassword')">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        let allUsuarios = [];
        let editandoId = null;

        async function cargarUsuarios() {
            try {
                const r = await fetch('/api/admin/usuarios', { credentials: 'include' });
                const d = await r.json();
                if (d.success) {
                    allUsuarios = d.usuarios || [];
                    renderUsuarios();
                }
            } catch (err) {
                console.error(err);
            }
        }

        function renderUsuarios() {
            const body = document.getElementById('usuariosBody');
            if (allUsuarios.length === 0) {
                body.innerHTML = '<tr><td colspan="5" class="empty-state">No hay usuarios</td></tr>';
                return;
            }
            body.innerHTML = allUsuarios.map(u => `
                <tr>
                    <td><strong>${u.username}</strong></td>
                    <td>${u.nombre}</td>
                    <td><span class="badge badge-${u.rol}">${u.rol.toUpperCase()}</span></td>
                    <td>${u.activo ? '✓ Activo' : '✗ Inactivo'}</td>
                    <td>
                        <button class="btn-action btn-edit" onclick="abrirModalEditar(${u.id})">Editar</button>
                        <button class="btn-action btn-delete" onclick="eliminarUsuario(${u.id})">Eliminar</button>
                    </td>
                </tr>
            `).join('');
        }

        function filtrarUsuarios() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const filtered = allUsuarios.filter(u =>
                u.nombre.toLowerCase().includes(search) ||
                u.username.toLowerCase().includes(search)
            );
            const body = document.getElementById('usuariosBody');
            if (filtered.length === 0) {
                body.innerHTML = '<tr><td colspan="5" class="empty-state">No hay usuarios que coincidan</td></tr>';
                return;
            }
            body.innerHTML = filtered.map(u => `
                <tr>
                    <td><strong>${u.username}</strong></td>
                    <td>${u.nombre}</td>
                    <td><span class="badge badge-${u.rol}">${u.rol.toUpperCase()}</span></td>
                    <td>${u.activo ? '✓ Activo' : '✗ Inactivo'}</td>
                    <td>
                        <button class="btn-action btn-edit" onclick="abrirModalEditar(${u.id})">Editar</button>
                        <button class="btn-action btn-delete" onclick="eliminarUsuario(${u.id})">Eliminar</button>
                    </td>
                </tr>
            `).join('');
        }

        function abrirModalCrear() {
            editandoId = null;
            document.getElementById('modalTitle').textContent = 'Nuevo usuario';
            document.getElementById('usuarioForm').reset();
            document.getElementById('passwordGroup').style.display = 'block';
            document.getElementById('username').disabled = false;
            document.getElementById('modalUsuario').classList.add('active');
        }

        async function abrirModalEditar(id) {
            try {
                const r = await fetch(`/api/admin/usuarios/${id}`, { credentials: 'include' });
                const d = await r.json();
                if (d.success) {
                    editandoId = id;
                    document.getElementById('modalTitle').textContent = 'Editar usuario';
                    document.getElementById('username').value = d.usuario.username;
                    document.getElementById('nombre').value = d.usuario.nombre;
                    document.getElementById('rol').value = d.usuario.rol;
                    document.getElementById('activo').checked = d.usuario.activo;
                    document.getElementById('passwordGroup').style.display = 'none';
                    document.getElementById('username').disabled = true;
                    document.getElementById('modalUsuario').classList.add('active');
                }
            } catch (err) {
                alert('Error al cargar usuario');
            }
        }

        async function guardarUsuario(e) {
            e.preventDefault();
            const username = document.getElementById('username').value;
            const nombre = document.getElementById('nombre').value;
            const rol = document.getElementById('rol').value;
            const password = document.getElementById('password').value;
            const activo = document.getElementById('activo').checked;

            if (!username || !nombre || !rol) {
                alert('Por favor completa los campos requeridos');
                return;
            }

            try {
                if (editandoId) {
                    const r = await fetch(`/api/admin/usuarios/${editandoId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ nombre, rol, activo })
                    });
                    const d = await r.json();
                    if (!d.success) {
                        alert('Error: ' + d.error);
                        return;
                    }
                } else {
                    if (!password) {
                        alert('Contraseña requerida para nuevo usuario');
                        return;
                    }
                    const r = await fetch('/api/admin/usuarios', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ username, nombre, rol, password })
                    });
                    const d = await r.json();
                    if (!d.success) {
                        alert('Error: ' + d.error);
                        return;
                    }
                }
                cerrarModal('modalUsuario');
                cargarUsuarios();
            } catch (err) {
                alert('Error: ' + err.message);
            }
        }

        function cerrarModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        async function cambiarContraseña(e) {
            e.preventDefault();
            const usuarioId = <%=usuario.id%>;
            const passwordActual = document.getElementById('passwordActual').value;
            const passwordNueva = document.getElementById('passwordNueva').value;

            try {
                const r = await fetch(`/api/admin/cambiar-contraseña/${usuarioId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ passwordActual, passwordNueva })
                });
                const d = await r.json();
                if (d.success) {
                    alert('Contraseña actualizada correctamente');
                    cerrarModal('modalPassword');
                } else {
                    alert('Error: ' + d.error);
                }
            } catch (err) {
                alert('Error: ' + err.message);
            }
        }

        async function eliminarUsuario(id) {
            if (!confirm('¿Estás seguro de que deseas eliminar este usuario?')) return;
            alert('Eliminación deshabilitada en esta versión. Usa editar para desactivar.');
        }

        cargarUsuarios();
    </script>
</body>
</html>
