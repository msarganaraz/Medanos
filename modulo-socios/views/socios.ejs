<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Socios — Club Médanos Verdes</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>👥 Socios</h1>
            <p>Gestión de socios del club</p>
        </div>

        <div class="top-bar">
            <button class="btn btn-primary" onclick="abrirModalCrear()">+ Nuevo socio</button>
            <a href="/dashboard" class="btn btn-secondary">← Volver al dashboard</a>
        </div>

        <div class="content-card">
            <div class="search-bar">
                <input type="text" id="searchInput" placeholder="Buscar socio por nombre, apellido o DNI..." onkeyup="filtrarSocios()">
            </div>

            <table id="sociosTable">
                <thead>
                    <tr>
                        <th>N° Socio</th>
                        <th>Apellido, Nombre</th>
                        <th>DNI</th>
                        <th>Teléfono</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody id="sociosBody">
                    <tr><td colspan="6" class="empty-state">Cargando socios...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal Crear/Editar -->
    <div class="modal" id="modalSocio">
        <div style="position: relative;">
            <button class="modal-close" onclick="cerrarModal('modalSocio')">✕</button>
            <div class="modal-content">
                <div class="modal-header" id="modalTitle">Nuevo socio</div>
                <form id="socioForm" onsubmit="guardarSocio(event)">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                        <div class="form-group">
                            <label>Apellido *</label>
                            <input type="text" id="apellido" required>
                        </div>
                        <div class="form-group">
                            <label>Nombre *</label>
                            <input type="text" id="nombre" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>DNI</label>
                        <input type="text" id="dni">
                    </div>
                    <div class="form-group">
                        <label>Fecha de nacimiento</label>
                        <input type="date" id="fecha_nacimiento">
                    </div>
                    <div class="form-group">
                        <label>Teléfono</label>
                        <input type="tel" id="telefono">
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" id="email">
                    </div>
                    <div class="form-group">
                        <label>Domicilio</label>
                        <input type="text" id="domicilio">
                    </div>
                    <div class="form-group" id="estadoGroup" style="display: none;">
                        <label>Estado</label>
                        <select id="estado">
                            <option value="ACTIVO">Activo</option>
                            <option value="INACTIVO">Inactivo</option>
                            <option value="SUSPENDIDO">Suspendido</option>
                        </select>
                    </div>
                    <div class="form-group" id="observacionesGroup" style="display: none;">
                        <label>Observaciones</label>
                        <textarea id="observaciones" rows="3"></textarea>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn-submit">Guardar</button>
                        <button type="button" class="btn-cancel" onclick="cerrarModal('modalSocio')">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        let allSocios = [];
        let editandoId = null;

        async function cargarSocios() {
            try {
                const r = await fetch('/api/socios', { credentials: 'include' });
                const d = await r.json();
                if (d.success) {
                    allSocios = d.socios || [];
                    renderSocios();
                }
            } catch (err) {
                console.error(err);
            }
        }

        function renderSocios() {
            const body = document.getElementById('sociosBody');
            if (allSocios.length === 0) {
                body.innerHTML = '<tr><td colspan="6" class="empty-state">No hay socios</td></tr>';
                return;
            }
            body.innerHTML = allSocios.map(s => `
                <tr onclick="abrirLegajo(${s.id})">
                    <td><strong>${s.numero_socio}</strong></td>
                    <td>${s.apellido}, ${s.nombre}</td>
                    <td>${s.dni || '—'}</td>
                    <td>${s.telefono || '—'}</td>
                    <td><span class="badge badge-${s.estado.toLowerCase()}">${s.estado}</span></td>
                    <td onclick="event.stopPropagation()">
                        <button class="btn-action" onclick="abrirModalEditar(${s.id})">Editar</button>
                    </td>
                </tr>
            `).join('');
        }

        function filtrarSocios() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const filtered = allSocios.filter(s =>
                s.nombre.toLowerCase().includes(search) ||
                s.apellido.toLowerCase().includes(search) ||
                (s.dni && s.dni.includes(search)) ||
                s.numero_socio.includes(search)
            );
            const body = document.getElementById('sociosBody');
            if (filtered.length === 0) {
                body.innerHTML = '<tr><td colspan="6" class="empty-state">No hay socios que coincidan</td></tr>';
                return;
            }
            body.innerHTML = filtered.map(s => `
                <tr onclick="abrirLegajo(${s.id})">
                    <td><strong>${s.numero_socio}</strong></td>
                    <td>${s.apellido}, ${s.nombre}</td>
                    <td>${s.dni || '—'}</td>
                    <td>${s.telefono || '—'}</td>
                    <td><span class="badge badge-${s.estado.toLowerCase()}">${s.estado}</span></td>
                    <td onclick="event.stopPropagation()">
                        <button class="btn-action" onclick="abrirModalEditar(${s.id})">Editar</button>
                    </td>
                </tr>
            `).join('');
        }

        function abrirModalCrear() {
            editandoId = null;
            document.getElementById('modalTitle').textContent = 'Nuevo socio';
            document.getElementById('socioForm').reset();
            document.getElementById('estadoGroup').style.display = 'none';
            document.getElementById('observacionesGroup').style.display = 'none';
            document.getElementById('modalSocio').classList.add('active');
        }

        async function abrirModalEditar(id) {
            try {
                const r = await fetch(`/api/socios/${id}`, { credentials: 'include' });
                const d = await r.json();
                if (d.success) {
                    const s = d.socio;
                    editandoId = id;
                    document.getElementById('modalTitle').textContent = 'Editar socio';
                    document.getElementById('apellido').value = s.apellido;
                    document.getElementById('nombre').value = s.nombre;
                    document.getElementById('dni').value = s.dni || '';
                    document.getElementById('fecha_nacimiento').value = s.fecha_nacimiento || '';
                    document.getElementById('telefono').value = s.telefono || '';
                    document.getElementById('email').value = s.email || '';
                    document.getElementById('domicilio').value = s.domicilio || '';
                    document.getElementById('estado').value = s.estado;
                    document.getElementById('observaciones').value = s.observaciones || '';
                    document.getElementById('estadoGroup').style.display = 'block';
                    document.getElementById('observacionesGroup').style.display = 'block';
                    document.getElementById('modalSocio').classList.add('active');
                }
            } catch (err) {
                alert('Error al cargar socio');
            }
        }

        async function guardarSocio(e) {
            e.preventDefault();
            const apellido = document.getElementById('apellido').value;
            const nombre = document.getElementById('nombre').value;
            const dni = document.getElementById('dni').value;
            const fecha_nacimiento = document.getElementById('fecha_nacimiento').value;
            const telefono = document.getElementById('telefono').value;
            const email = document.getElementById('email').value;
            const domicilio = document.getElementById('domicilio').value;

            try {
                if (editandoId) {
                    const estado = document.getElementById('estado').value;
                    const observaciones = document.getElementById('observaciones').value;
                    const r = await fetch(`/api/socios/${editandoId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ apellido, nombre, dni, fecha_nacimiento, telefono, email, domicilio, estado, observaciones })
                    });
                    const d = await r.json();
                    if (!d.success) {
                        alert('Error: ' + d.error);
                        return;
                    }
                } else {
                    const r = await fetch('/api/socios', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ apellido, nombre, dni, fecha_nacimiento, telefono, email, domicilio })
                    });
                    const d = await r.json();
                    if (!d.success) {
                        alert('Error: ' + d.error);
                        return;
                    }
                }
                cerrarModal('modalSocio');
                cargarSocios();
            } catch (err) {
                alert('Error: ' + err.message);
            }
        }

        function cerrarModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        function abrirLegajo(id) {
            window.location.href = `/socios/${id}/legajo`;
        }

        cargarSocios();
    </script>
</body>
</html>
