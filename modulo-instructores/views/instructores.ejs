<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Instructores — Club Médanos Verdes</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🏋️ Instructores</h1>
            <p>Gestión de instructores y contratos</p>
        </div>

        <div class="top-bar">
            <button class="btn btn-primary" onclick="abrirModalCrear()">+ Nuevo instructor</button>
            <a href="/liquidaciones" class="btn btn-primary">Ver liquidaciones</a>
            <a href="/dashboard" class="btn btn-secondary">← Volver al dashboard</a>
        </div>

        <div class="content-card">
            <div class="search-bar">
                <input type="text" id="searchInput" placeholder="Buscar instructor..." onkeyup="filtrarInstructores()">
            </div>

            <table id="instructoresTable">
                <thead>
                    <tr>
                        <th>Apellido, Nombre</th>
                        <th>Tipo de contrato</th>
                        <th>Monto/Valor</th>
                        <th>Teléfono</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody id="instructoresBody">
                    <tr><td colspan="5" class="empty-state">Cargando instructores...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal Crear/Editar -->
    <div class="modal" id="modalInstructor">
        <div style="position: relative;">
            <button class="modal-close" onclick="cerrarModal('modalInstructor')">✕</button>
            <div class="modal-content">
                <div class="modal-header" id="modalTitle">Nuevo instructor</div>
                <form id="instructorForm" onsubmit="guardarInstructor(event)">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                        <div class="form-group">
                            <label>Apellido *</label>
                            <input type="text" id="apellido" required>
                        </div>
                        <div class="form-group">
                            <label>Nombre *</label>
                            <input type="text" id="nombre" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Tipo de contrato *</label>
                        <select id="tipo_contrato" onchange="actualizarCamposMonto()" required>
                            <option value="">Seleccionar...</option>
                            <option value="fijo">Fijo mensual</option>
                            <option value="por_hora">Por hora</option>
                            <option value="por_alumno">Por alumno</option>
                            <option value="combinado">Combinado</option>
                        </select>
                    </div>
                    <div class="form-group" id="montoFijoGroup">
                        <label>Monto fijo</label>
                        <input type="number" id="monto_fijo" step="0.01" value="0">
                    </div>
                    <div class="form-group" id="valorHoraGroup" style="display: none;">
                        <label>Valor por hora</label>
                        <input type="number" id="valor_hora" step="0.01" value="0">
                    </div>
                    <div class="form-group" id="valorAlumnoGroup" style="display: none;">
                        <label>Valor por alumno</label>
                        <input type="number" id="valor_por_alumno" step="0.01" value="0">
                    </div>
                    <div class="form-group">
                        <label>Teléfono</label>
                        <input type="tel" id="telefono">
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" id="email">
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn-submit">Guardar</button>
                        <button type="button" class="btn-cancel" onclick="cerrarModal('modalInstructor')">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Detalle -->
    <div class="modal" id="modalDetalle">
        <div style="position: relative;">
            <button class="modal-close" onclick="cerrarModal('modalDetalle')">✕</button>
            <div class="modal-content">
                <div class="modal-header" id="detalleTitle">Instructor</div>
                <div style="line-height: 1.8; margin-bottom: 24px;">
                    <div style="margin-bottom: 12px;">
                        <span style="color: var(--neutral-500); font-size: var(--text-sm);">Tipo de contrato</span>
                        <div style="font-weight: var(--weight-semibold); color: var(--neutral-900);" id="detalleTipo">—</div>
                    </div>
                    <div style="margin-bottom: 12px;">
                        <span style="color: var(--neutral-500); font-size: var(--text-sm);">Monto/Valor</span>
                        <div style="font-weight: var(--weight-semibold); color: var(--neutral-900);" id="detalleValor">—</div>
                    </div>
                    <div style="margin-bottom: 12px;">
                        <span style="color: var(--neutral-500); font-size: var(--text-sm);">Teléfono</span>
                        <div style="font-weight: var(--weight-semibold); color: var(--neutral-900);" id="detalleTelefono">—</div>
                    </div>
                    <div>
                        <span style="color: var(--neutral-500); font-size: var(--text-sm);">Email</span>
                        <div style="font-weight: var(--weight-semibold); color: var(--neutral-900);" id="detalleEmail">—</div>
                    </div>
                </div>

                <div style="border-top: 1px solid var(--neutral-200); padding-top: 24px; margin-bottom: 24px;">
                    <h4 style="font-size: var(--text-lg); font-weight: var(--weight-semibold); margin-bottom: 12px; color: var(--neutral-900);">Actividades asignadas</h4>
                    <div id="detalleActividades" style="display: flex; flex-direction: column; gap: 8px;">
                        <div style="color: var(--neutral-400); font-size: var(--text-sm);">Cargando...</div>
                    </div>
                </div>

                <div style="border-top: 1px solid var(--neutral-200); padding-top: 24px; text-align: right;">
                    <button type="button" class="btn btn-secondary" onclick="cerrarModal('modalDetalle')">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        let allInstructores = [];
        let editandoId = null;

        function actualizarCamposMonto() {
            const tipo = document.getElementById('tipo_contrato').value;
            document.getElementById('montoFijoGroup').style.display = tipo === 'fijo' || tipo === 'combinado' ? 'block' : 'none';
            document.getElementById('valorHoraGroup').style.display = tipo === 'por_hora' || tipo === 'combinado' ? 'block' : 'none';
            document.getElementById('valorAlumnoGroup').style.display = tipo === 'por_alumno' || tipo === 'combinado' ? 'block' : 'none';
        }

        async function cargarInstructores() {
            try {
                const r = await fetch('/api/instructores', { credentials: 'include' });
                const d = await r.json();
                if (d.success) {
                    allInstructores = d.instructores || [];
                    renderInstructores();
                }
            } catch (err) {
                console.error(err);
            }
        }

        function renderInstructores() {
            const body = document.getElementById('instructoresBody');
            if (allInstructores.length === 0) {
                body.innerHTML = '<tr><td colspan="5" class="empty-state">No hay instructores</td></tr>';
                return;
            }
            body.innerHTML = allInstructores.map(i => {
                let monto = '—';
                if (i.tipo_contrato === 'fijo') monto = `$${i.monto_fijo}`;
                else if (i.tipo_contrato === 'por_hora') monto = `$${i.valor_hora}/h`;
                else if (i.tipo_contrato === 'por_alumno') monto = `$${i.valor_por_alumno}/a`;
                else monto = `F:$${i.monto_fijo}+H:$${i.valor_hora}+A:$${i.valor_por_alumno}`;
                return `
                    <tr>
                        <td>${i.apellido}, ${i.nombre}</td>
                        <td><span class="badge badge-${i.tipo_contrato}">${i.tipo_contrato.toUpperCase()}</span></td>
                        <td>${monto}</td>
                        <td>${i.telefono || '—'}</td>
                        <td style="display: flex; gap: 6px;">
                            <button class="btn-action" onclick="abrirModalDetalle(${i.id})">Ver</button>
                            <button class="btn-action btn-edit" onclick="abrirModalEditar(${i.id})">Editar</button>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function filtrarInstructores() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const filtered = allInstructores.filter(i =>
                i.nombre.toLowerCase().includes(search) ||
                i.apellido.toLowerCase().includes(search)
            );
            const body = document.getElementById('instructoresBody');
            if (filtered.length === 0) {
                body.innerHTML = '<tr><td colspan="5" class="empty-state">No hay instructores que coincidan</td></tr>';
                return;
            }
            body.innerHTML = filtered.map(i => {
                let monto = '—';
                if (i.tipo_contrato === 'fijo') monto = `$${i.monto_fijo}`;
                else if (i.tipo_contrato === 'por_hora') monto = `$${i.valor_hora}/h`;
                else if (i.tipo_contrato === 'por_alumno') monto = `$${i.valor_por_alumno}/a`;
                else monto = `F:$${i.monto_fijo}+H:$${i.valor_hora}+A:$${i.valor_por_alumno}`;
                return `
                    <tr>
                        <td>${i.apellido}, ${i.nombre}</td>
                        <td><span class="badge badge-${i.tipo_contrato}">${i.tipo_contrato.toUpperCase()}</span></td>
                        <td>${monto}</td>
                        <td>${i.telefono || '—'}</td>
                        <td style="display: flex; gap: 6px;">
                            <button class="btn-action" onclick="abrirModalDetalle(${i.id})">Ver</button>
                            <button class="btn-action btn-edit" onclick="abrirModalEditar(${i.id})">Editar</button>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function abrirModalCrear() {
            editandoId = null;
            document.getElementById('modalTitle').textContent = 'Nuevo instructor';
            document.getElementById('instructorForm').reset();
            actualizarCamposMonto();
            document.getElementById('modalInstructor').classList.add('active');
        }

        async function abrirModalEditar(id) {
            try {
                const r = await fetch(`/api/instructores/${id}`, { credentials: 'include' });
                const d = await r.json();
                if (d.success) {
                    const i = d.instructor;
                    editandoId = id;
                    document.getElementById('modalTitle').textContent = 'Editar instructor';
                    document.getElementById('apellido').value = i.apellido;
                    document.getElementById('nombre').value = i.nombre;
                    document.getElementById('tipo_contrato').value = i.tipo_contrato;
                    document.getElementById('monto_fijo').value = i.monto_fijo || 0;
                    document.getElementById('valor_hora').value = i.valor_hora || 0;
                    document.getElementById('valor_por_alumno').value = i.valor_por_alumno || 0;
                    document.getElementById('telefono').value = i.telefono || '';
                    document.getElementById('email').value = i.email || '';
                    actualizarCamposMonto();
                    document.getElementById('modalInstructor').classList.add('active');
                }
            } catch (err) {
                alert('Error al cargar instructor');
            }
        }

        async function guardarInstructor(e) {
            e.preventDefault();
            const apellido = document.getElementById('apellido').value;
            const nombre = document.getElementById('nombre').value;
            const tipo_contrato = document.getElementById('tipo_contrato').value;
            const monto_fijo = parseFloat(document.getElementById('monto_fijo').value);
            const valor_hora = parseFloat(document.getElementById('valor_hora').value);
            const valor_por_alumno = parseFloat(document.getElementById('valor_por_alumno').value);
            const telefono = document.getElementById('telefono').value;
            const email = document.getElementById('email').value;

            try {
                if (editandoId) {
                    const r = await fetch(`/api/instructores/${editandoId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ apellido, nombre, tipo_contrato, monto_fijo, valor_hora, valor_por_alumno, telefono, email, activo: true })
                    });
                    const d = await r.json();
                    if (!d.success) { alert('Error: ' + d.error); return; }
                } else {
                    const r = await fetch('/api/instructores', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ apellido, nombre, tipo_contrato, monto_fijo, valor_hora, valor_por_alumno, telefono, email })
                    });
                    const d = await r.json();
                    if (!d.success) { alert('Error: ' + d.error); return; }
                }
                cerrarModal('modalInstructor');
                cargarInstructores();
            } catch (err) {
                alert('Error: ' + err.message);
            }
        }

        async function abrirModalDetalle(id) {
            try {
                const r = await fetch(`/api/instructores/${id}`, { credentials: 'include' });
                const d = await r.json();
                if (!d.success) {
                    alert('Error: ' + d.error);
                    return;
                }

                const i = d.instructor;
                const actividades = d.actividades || [];

                document.getElementById('detalleTitle').textContent = `${i.apellido}, ${i.nombre}`;

                const tipoLabels = { fijo: 'Fijo mensual', por_hora: 'Por hora', por_alumno: 'Por alumno', combinado: 'Combinado' };
                document.getElementById('detalleTipo').textContent = tipoLabels[i.tipo_contrato] || i.tipo_contrato;

                let valor = '—';
                if (i.tipo_contrato === 'fijo') valor = `$${i.monto_fijo.toFixed(2)}/mes`;
                else if (i.tipo_contrato === 'por_hora') valor = `$${i.valor_hora.toFixed(2)}/hora`;
                else if (i.tipo_contrato === 'por_alumno') valor = `$${i.valor_por_alumno.toFixed(2)}/alumno`;
                else if (i.tipo_contrato === 'combinado')
                    valor = `Fijo: $${i.monto_fijo.toFixed(2)} + Hora: $${i.valor_hora.toFixed(2)} + Alumno: $${i.valor_por_alumno.toFixed(2)}`;
                document.getElementById('detalleValor').textContent = valor;

                document.getElementById('detalleTelefono').textContent = i.telefono || '—';
                document.getElementById('detalleEmail').textContent = i.email || '—';

                var diasAbrev = ['Lun', 'Mar', 'Mie', 'Jue', 'Vie', 'Sab', 'Dom'];
                function formatFranjas(franjas) {
                    if (!franjas || franjas.length === 0) return 'Sin horario asignado';
                    return franjas.map(function(f) {
                        var hi = f.hora_inicio < 10 ? '0' + f.hora_inicio : '' + f.hora_inicio;
                        var hf = f.hora_fin < 10 ? '0' + f.hora_fin : '' + f.hora_fin;
                        return diasAbrev[f.dia_semana] + ' ' + hi + ':00-' + hf + ':00';
                    }).join(', ');
                }

                var actividadesHtml = '';
                if (actividades.length === 0) {
                    actividadesHtml = '<div style="color: var(--neutral-400); font-size: var(--text-sm);">Sin actividades asignadas</div>';
                } else {
                    actividades.forEach(function(a) {
                        actividadesHtml += '<div style="padding: 8px; background: var(--neutral-50); border-radius: var(--radius-md); border-left: 3px solid var(--primary); margin-bottom: 6px;">' +
                            '<div style="font-weight: 600; color: var(--neutral-900);">' + a.nombre + '</div>' +
                            '<div style="font-size: 13px; color: var(--neutral-500);">' + formatFranjas(a.franjas) + '</div>' +
                            '</div>';
                    });
                }

                document.getElementById('detalleActividades').innerHTML = actividadesHtml;
                document.getElementById('modalDetalle').classList.add('active');
            } catch (err) {
                alert('Error: ' + err.message);
            }
        }

        function cerrarModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        cargarInstructores();
    </script>
</body>
</html>
