<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> — Club Médanos Verdes</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
    <style>
        .header {
            background: linear-gradient(135deg, #2d6219 0%, #4a8c2a 100%);
            color: white;
            padding: 24px 40px;
            margin: -20px -20px 30px -20px;
            box-shadow: 0 4px 12px rgba(45, 98, 25, 0.15);
        }

        .header h1 {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .header p {
            opacity: 0.9;
            font-size: 14px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        .module-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            flex-wrap: wrap;
            gap: 20px;
        }

        .module-title {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .module-title-icon {
            font-size: 32px;
        }

        .module-title-text h1 {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .module-title-text p {
            font-size: 13px;
            color: #64748b;
        }

        .toolbar {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .section-title {
            font-size: 16px;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 20px;
            padding-bottom: 12px;
            border-bottom: 2px solid #2d6219;
            display: inline-block;
        }

        .search-bar {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .search-bar input,
        .search-bar select {
            padding: 10px 14px;
            border: 1.5px solid #e5e7eb;
            border-radius: 8px;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            transition: all 0.2s;
        }

        .search-bar input:focus,
        .search-bar select:focus {
            outline: none;
            border-color: #2d6219;
            box-shadow: 0 0 0 3px rgba(45, 98, 25, 0.1);
        }

        .search-bar input {
            flex: 1;
            min-width: 250px;
        }

        .tabs {
            display: flex;
            gap: 8px;
            margin-bottom: 24px;
            border-bottom: 2px solid #e5e7eb;
        }

        .tab {
            padding: 12px 16px;
            background: none;
            border: none;
            cursor: pointer;
            font-weight: 500;
            color: #64748b;
            border-bottom: 3px solid transparent;
            transition: all 0.2s;
            font-family: 'DM Sans', sans-serif;
        }

        .tab:hover {
            color: #2d6219;
        }

        .tab.active {
            color: #2d6219;
            border-bottom-color: #2d6219;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }
    </style>
    <%- typeof customStyles !== 'undefined' ? customStyles : '' %>
</head>
<body>
    <div class="container">
        <div class="header">
            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
                <div>
                    <h1><%= icon %> <%= title %></h1>
                    <p><%= description %></p>
                </div>
                <% if (typeof backLink !== 'undefined' && backLink) { %>
                    <a href="<%= backLink %>" class="btn btn-secondary">← Volver</a>
                <% } %>
            </div>
        </div>

        <%- body %>
    </div>
</body>
</html>
